{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Products with up to 3 photos"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "tagline": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "required": true
    },
    "subText": {
      "type": "text"
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "required": false
    },
    "description": {
      "type": "richtext"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "price": {
      "type": "decimal"
    },
    "showOnHomepage": {
      "type": "boolean",
      "default": true
    }
  }
}
